# Copy this file to `.env` and fill in the PRODUCTION values.
# Do NOT commit `.env` or `credentials.json` — they are secrets (already gitignored).

# --- Google Custom Search (image search) ---
# API key from Google Cloud console (Custom Search API).
GOOGLE_CSE_API_KEYS=your-cse-api-key-here
# The Custom Search Engine ID (the "cx" value).
GOOGLE_CSE_CX=your-cse-cx-here

# --- Google Vertex AI (Gemini image selection) ---
# Path to the service-account JSON key. Relative paths are resolved from this repo.
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
# The GCP project that has Vertex AI enabled, and the region to call.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
